{
  "colors": {
    "primary":      "#d6b328",
    "primary_light": "#e8cc5a",
    "primary_dark":  "#a8891c",
    "secondary":    "#217443",
    "accent":       "#62c794",
    "background":   "#f5f9f6",
    "surface":      "#ffffff",
    "surface_dark": "#0f1e17",
    "text_primary": "#0d1a12",
    "text_secondary": "#4a6155",
    "text_light":   "#FFFFFF",
    "border":       "#d4e6db"
  },
  "fonts": {
    "heading":       "Oswald",
    "body":          "Nunito Sans",
    "google_import": "https://fonts.googleapis.com/css2?family=Oswald:wght@400;600;700&family=Nunito+Sans:ital,opsz,wght@0,6..12,400;0,6..12,500;0,6..12,600;0,6..12,700;1,6..12,400&display=swap"
  },
  "gradients": {
    "hero_overlay":   "radial-gradient(ellipse at 50% 0%, #1a5e35 0%, #0f1e17 80%)",
    "card_overlay":   "linear-gradient(180deg, transparent 50%, rgba(15,30,23,0.75) 100%)",
    "cta_overlay":    "linear-gradient(135deg, #0f1e17 0%, #1a3326 100%)",
    "section_bg":     "linear-gradient(180deg, #f5f9f6 0%, #eef5f1 100%)",
    "gradient_blob_1": "radial-gradient(circle, #217443 0%, transparent 65%)",
    "gradient_blob_2": "radial-gradient(circle, #d6b328 0%, transparent 70%)"
  },
  "style": {
    "border_radius":    "0.125rem",
    "border_radius_lg": "0.25rem",
    "border_radius_xl": "0.5rem",
    "border_radius_full": "9999px",
    "shadow_sm": "0 1px 3px 0 rgb(0 0 0 / 0.05)",
    "shadow_md": "0 4px 12px -1px rgb(0 0 0 / 0.08)",
    "shadow_lg": "0 12px 30px -5px rgb(13 26 18 / 0.10)",
    "shadow_xl": "0 20px 40px -8px rgb(13 26 18 / 0.14)"
  },
  "glass": {
    "card_dark":  "background: rgba(255,255,255,0.08); backdrop-filter: blur(12px); border: 1px solid rgba(255,255,255,0.12); border-radius: 0.5rem;",
    "card_light": "background: rgba(255,255,255,0.85); backdrop-filter: blur(8px); border: 1px solid rgba(212,230,219,0.60); border-radius: 0.25rem;",
    "input":      "background: rgba(255,255,255,0.10); backdrop-filter: blur(12px); border: 1px solid rgba(255,255,255,0.18); border-radius: 0.125rem; color: #FFFFFF;"
  },
  "animations": {
    "float_slow":   "float-slow 9s ease-in-out infinite alternate",
    "ken_burns":    "kenBurns 12s ease-in-out infinite alternate",
    "cta_pulse":    "ctaPulse 2s ease-in-out infinite",
    "shimmer_sweep": "shimmerSweep 1.2s ease-in forwards",
    "chip_pop":     "chipPop 0.4s cubic-bezier(0.34,1.56,0.64,1) forwards",
    "marquee_left": "marqueeLeft 40s linear infinite",
    "marquee_right": "marqueeRight 40s linear infinite"
  },
  "nav": {
    "transparent_state": {
      "background": "transparent",
      "border":     "none",
      "shadow":     "none",
      "link_color": "#FFFFFF",
      "cta_bg":     "#d6b328",
      "cta_text":   "#0d1a12",
      "note":       "CRITICAL: cta_bg and cta_text are hardcoded — never transparent over hero"
    },
    "scrolled_state": {
      "background": "rgba(255,255,255,0.96)",
      "backdrop_filter": "blur(12px)",
      "border":     "1px solid rgba(214,179,40,0.30)",
      "shadow":     "0 1px 8px rgba(13,26,18,0.08)",
      "link_color": "#0d1a12",
      "cta_bg":     "#d6b328",
      "cta_text":   "#0d1a12",
      "transition":  "all 300ms ease",
      "trigger_px": 80
    }
  },
  "rtl": false
}
